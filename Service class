public class Service {
    
    private String serviceId;
    private String serviceName;
    private String description;
    private double price;
    private String reservationId;
    private String requestDate;
    private String serviceStatus;

    public Service(String serviceId, String serviceName, String description, double price, String reservationId, String requestDate, String serviceStatus) {
      setServiceId(serviceId);
       setServiceName(serviceName);
       setDescription(description);
       setPrice(price);
       setReservationId(reservationId);
        setRequestDate(requestDate);
       setServiceStatus(serviceStatus);
    }

    
    
    
    
    public void setServiceId(String serviceId) {
        if((serviceId!=null)&&(!serviceId.equals("")))
        this.serviceId = serviceId;
    }

    public void setServiceName(String serviceName) {
        if((serviceName!=null)&&(!serviceName.equals("")))
        this.serviceName = serviceName;
    }

    public void setDescription(String description) {
        if((description!=null)&&(!description.equals("")))
        this.description = description;
    }

    public void setPrice(double price) {
        if(price<0)
        this.price = price;
    }

    public void setReservationId(String reservationId) {
        if((reservationId!=null)&&(!reservationId.equals("")))
        this.reservationId = reservationId;
    }

    public void setRequestDate(String requestDate) {
        if((requestDate!=null)&&(!requestDate.equals("")))
        this.requestDate = requestDate;
    }

    public void setServiceStatus(String serviceStatus) {
        if((serviceStatus.equals("Requested"))||(serviceStatus.equals("In Progress"))||(serviceStatus.equals("Completed"))||(serviceStatus.equals("Cancelled")))
        this.serviceStatus = serviceStatus;
    }

    public String getServiceId() {
        return serviceId;
    }

    public String getServiceName() {
        return serviceName;
    }

    public String getDescription() {
        return description;
    }

    public double getPrice() {
        return price;
    }

    public String getReservationId() {
        return reservationId;
    }

    public String getRequestDate() {
        return requestDate;
    }

    public String getServiceStatus() {
        return serviceStatus;
    }
    
    
    
    
    
    
}
