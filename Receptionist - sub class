

package hotelapp;

import java.util.Arrays;
import java.util.Collections;
import java.util.LinkedList;
import java.util.Scanner;
public class Receptionist extends User {
    
    private Guest guest;

    public Receptionist(Guest guest, String userId, String userJoiningDate, String userName, String userEmail, String userPhone, String userAddress, String role) {
        super(userId, userJoiningDate, userName, userEmail, userPhone, userAddress, role);
        this.guest = guest;
    }
    
    public void CheckInAGuest(String guestID, String reservationID, User [] guests){
        Guest g;
        for (int i = 0; i < guests.length; i++) {
            if(guests[i] instanceof Guest){
                g = (Guest)guests[i];
                if(g.getGuestReservation().getAssociatedGuestID() == guestID & g.getGuestReservation().getReservationID() == reservationID & g.getGuestReservation().getReservationStatus() == "Confirmed"){
                    g.getGuestReservation().setReservationStatus("Checked-In");
                    g.getGuestReservation().setRoomStatus("Occupied");
                }
            }
            
        }
    }
    
    public void CreateAWalkInReservation(LinkedList<Room> rooms) {
        Scanner in = new Scanner(System.in);

        System.out.println("Enter the check in date, check out dates, as well as the umber of guests:");

        System.out.print("Check in date (DD/MM/YYYY): ");
        String checkInDate = in.nextLine();

        System.out.print("\nCheck out date (DD/MM/YYYY): ");
        String checkOutDate = in.nextLine();

        System.out.println("\nNumber of guests (1-4): ");
        int numberOfguests = 0;
        while (numberOfguests <= 1 | numberOfguests >= 4) {
            System.out.println("Invalid!");
            numberOfguests = in.nextInt();
        }

        Reservation r;
        Collections.sort(rooms);
        int count = 0;
        for (Room room1 : rooms) {
            if (room1 instanceof Reservation) {
                r = (Reservation) (room1);

                if (checkInDate == r.getCheckInDate() & checkOutDate == r.getCheckOutDate() & numberOfguests == r.getNumberOfGuests()) {
                    continue;
                } else {
                    System.out.println(r + "\n");
                }
            } else if (room1.getRoomStatus() == "Available") {
                System.out.println(room1 + "\n");
            }

            count++;
        }

        if (count != 0) {
            System.out.println("Enter the room number for the room you would like to reserve: ");
            String roomNumber = in.next();
            System.out.println("Enter the guest ID: ");
            String guestID = in.nextLine();
            System.out.println("Enter the booking date: ");
            String bookingDate = in.nextLine();

            for (Room room1 : rooms) {
                if (roomNumber == room1.getRoomNumber()) {
                    rooms.add(new Reservation(guestID, checkInDate, checkOutDate, numberOfguests, "", bookingDate, room1.getRoomType(), room1.getFloorNumber(), room1.getBedType()));

                }

                if (room1 instanceof Reservation) {
                    continue;
                }

                rooms.remove(room1);
            }
        } else {
            System.out.println("There are no rooms available.");
        }
    }
}
