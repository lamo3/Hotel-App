    public void SearchAvailableRooms(String CheckInDate, String CheckOutDate, int guests, String roomType, LinkedList<Room> rooms) {

        Reservation r;
        Collections.sort(rooms);
        int count = 0;
        for (Room room1 : rooms) {
            if (room1 instanceof Reservation) {
                r = (Reservation) (room1);

                if (CheckInDate == r.getCheckInDate() & CheckOutDate == r.getCheckOutDate() & guests == r.getNumberOfGuests()) {
                    continue;
                } else {
                    System.out.println(r + "\n");
                }
            } else if (room1.getRoomStatus() == "Available") {
                System.out.println(room1 + "\n");
            }

            count++;
        }

        if (count == 0) {
            System.out.println("There are no rooms available");
        }
    }
